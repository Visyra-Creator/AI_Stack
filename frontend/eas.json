{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_USE_POCKETBASE": "true",
        "EXPO_PUBLIC_POCKETBASE_URL": "http://192.168.1.7:8090"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_USE_POCKETBASE": "true",
        "EXPO_PUBLIC_POCKETBASE_URL": "http://192.168.1.7:8090"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_USE_POCKETBASE": "true",
        "EXPO_PUBLIC_POCKETBASE_URL": "http://192.168.1.7:8090"
      }
    },
    "production-apk-local": {
      "extends": "production",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
