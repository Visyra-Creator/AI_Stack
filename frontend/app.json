{
  "expo": {
    "name": "AI Keeper",
    "slug": "ai-keeper",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "backgroundColor": "#000000"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.sagar3198.aistackkeeper3198"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 1600,
          "resizeMode": "cover",
          "backgroundColor": "#000000"
        }
      ],
      "expo-video",
      "expo-audio",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "sagar3198",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc98f1e3-e56e-4447-8744-1883feb062d5"
      }
    }
  }
}
